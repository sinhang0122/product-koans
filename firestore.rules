rules_version = '2';

// ════════════════════════════════════════════════════════════════════
//  KoAus · Firestore 보안 규칙
//  목적: 봇/매크로의 무한 읽기·쓰기로 인한 요금 폭탄(Billing Shock) 방어
//   - 쓰기(create): 로그인 + 필수 필드/타입/길이 검증 + 본인 소유만 허용
//   - 수정/삭제(update/delete): 글 작성자 본인만
//   - 목록 읽기(list): 한 번에 최대 20개까지만 (페이지네이션 강제)
//   - 정의되지 않은 모든 경로: 기본 거부(deny-all)
//  배포:  firebase deploy --only firestore:rules
// ════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 공통 헬퍼 ──
    function isSignedIn() {
      return request.auth != null;
    }
    // 본인인증 게이트 (H2) — UGC 글 생성은 폰 SMS 인증 OR 이메일 인증 계정만.
    //   · 클라(koausCanPost, koaus-phone-auth.js)와 동일 조건 "폰 OR 이메일인증"(둘 중 하나).
    //     ⚠️ "폰만" 요구하면 기존 이메일인증·Google 계정 글쓰기가 막힘(회귀) → 반드시 OR.
    //   · SDK 직접 호출로 미인증 계정이 글 생성하는 우회 차단(클라 게이트만으론 우회 가능).
    function isVerifiedUser() {
      return isSignedIn()
        && (request.auth.token.phone_number != null
            || request.auth.token.email_verified == true);
    }
    // 관리자 — 3중 안전망:
    //   ① Firebase Admin SDK(setAdmin.js)로 부여한 custom claim {admin: true}  ← 가장 안전·저비용
    //   ② 화이트리스트 이메일(token.email) 일치               ← 백업 + admin.html 동기화 필요
    //   ③ users/{uid}.isAdmin == true (Firestore get)         ← admin 콘솔에서 수동 토글 가능,
    //                                                            users 컬렉션 update 룰이 isAdmin
    //                                                            필드 변조를 막아야 안전.
    //   · 비용 영향: ③ get() 호출은 룰 평가당 read 1회 추가. ①·② 가 통과하면 ③ 평가 skip(단락).
    //   · 클라이언트 측 변조 차단: users 컬렉션 update 룰에 isAdmin/email 변조 거부 가드 추가됨.
    function isAdmin() {
      return isSignedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.email == 'sinhang0122@gmail.com'
          // koaus.official@gmail.com 권한 검증 제거 (사용자 명시 — sinhang0122 단독 운영자)
          //   · 단 mailto: 운영 연락처(terms/privacy 등) 는 그대로 사용 — 권한과 별개 채널
          || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
        );
    }
    function data() {
      return request.resource.data;
    }
    // 필수 문자열: 존재 + string 타입 + 길이 제한(거대 페이로드로 용량 폭증 차단)
    function reqStr(field, minLen, maxLen) {
      return field in data()
        && data()[field] is string
        && data()[field].size() >= minLen
        && data()[field].size() <= maxLen;
    }
    // 선택 문자열: 없거나 / 있으면 string + 최대 길이 제한
    function optStr(field, maxLen) {
      return !(field in data())
        || (data()[field] is string && data()[field].size() <= maxLen);
    }
    // 선택 숫자: 없거나 / 있으면 int + 범위 내
    function optInt(field, minVal, maxVal) {
      return !(field in data())
        || (data()[field] is int && data()[field] >= minVal && data()[field] <= maxVal);
    }
    // 선택 URL 리스트: 없거나 / list + 길이 제한 (이미지 URL 배열용)
    function optUrlList(field, maxCount) {
      return !(field in data())
        || (data()[field] is list && data()[field].size() <= maxCount);
    }
    // 선택 bool: 없거나 / 있으면 bool 타입
    function optBool(field) {
      return !(field in data()) || data()[field] is bool;
    }
    // 목록 조회는 반드시 20개 이하만 — 무한 스캔(read 폭탄) 차단
    function limitedList() {
      return request.query.limit <= 20;
    }
    // ── 정지 계정 쓰기 차단 (제재 시스템 1단계) ──
    //   · suspendUser callable(Functions)이 Auth disable + users/{uid}.status='suspended' 부여.
    //     Auth disable 후에도 기존 ID 토큰이 최대 1시간 유효 → 본 체크가 그 창을 닫는다.
    //   · doc 없음 / status 필드 없음 = active 취급 (옛 가입자 에러 0 — 마이그레이션 불필요)
    //   · 비용: 같은 요청 내 동일 doc 의 get/exists 는 캐시되어 1회만 과금 —
    //     isAdmin() ③ 이 이미 users/{uid} 를 읽는 경로(소유자 update/delete, services create)는
    //     추가 read 0. 게시판 create 만 +1 read/쓰기 (빈도 낮음 — 무시 가능).
    function notSuspended() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid))
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'active') != 'suspended';
    }

    // ── 게시판 글 검증 ──
    // 작성자 본인 확인 (update/delete 용) — create 시 위조 차단은 validBaseCreate 가 담당
    //   · notSuspended — 정지 계정은 본인 글 수정/삭제도 차단 (제재 1단계)
    function ownerOnExisting() {
      return isSignedIn() && resource.data.uid == request.auth.uid && notSuspended();
    }
    // ── 게시판 검증 v2 — 1,000 표현식 평가 한도(공식 limit) 방어 구조 ──
    //   배경: 기존 단일 검증기의 ~57개 && 체인 + 헬퍼마다 data() 함수 재호출이
    //         Firestore rules 의 요청당 "최대 1,000 표현식 평가" 한도를 초과
    //         → 필드 많은 accom/rent create 가 무조건 deny 되는 회귀 발생 (2026-06).
    //   대책: ① request.resource.data 를 let 으로 1회 바인딩 후 인자(d)로 전달
    //         ② 게시판별 검증기 분리 — 해당 게시판 필드만 평가 (비용↓ + 교차 필드 주입 차단↑)
    //   주의: 필드 추가 시 해당 게시판 검증기 + hasOnly 목록만 갱신. 전 게시판 공통이면 validBaseCreate.
    function pReqStr(d, field, minLen, maxLen) {
      return field in d && d[field] is string
        && d[field].size() >= minLen && d[field].size() <= maxLen;
    }
    function pOptStr(d, field, maxLen) {
      return !(field in d) || (d[field] is string && d[field].size() <= maxLen);
    }
    function pOptInt(d, field, minVal, maxVal) {
      return !(field in d) || (d[field] is int && d[field] >= minVal && d[field] <= maxVal);
    }
    function pOptList(d, field, maxCount) {
      return !(field in d) || (d[field] is list && d[field].size() <= maxCount);
    }
    function pOptBool(d, field) {
      return !(field in d) || d[field] is bool;
    }
    // 전 게시판 공통 메타/연락처 검증 (소유자 위조 차단 포함)
    function validBaseCreate(d) {
      return isVerifiedUser() && 'uid' in d && d.uid == request.auth.uid
        && notSuspended()
        && pReqStr(d, 'title', 1, 120)
        // 공백만으로 채운 제목 차단 (M5) — body 는 제외: 클라이언트가 빈 본문을 ' ' 로 보정하는 기존 설계 유지
        && d.title.trim().size() >= 1
        && pReqStr(d, 'body', 1, 5000)
        && pOptStr(d, 'state', 10)
        && pOptStr(d, 'mode', 20)
        && pOptStr(d, 'address', 300)
        && pOptStr(d, 'contact', 100)
        && pOptStr(d, 'phone', 30)
        && pOptStr(d, 'kakaoLink', 500)
        && pOptStr(d, 'author', 50)
        && pOptStr(d, 'contactEmail', 200)   // 글쓴이 연락용 이메일(선택) — 계정 PII email/authorEmail 과 별개 키
        // H4: 공개 문서 작성자 PII 제거 — email 미허용(소유권은 uid/authorUid).
        && !('email' in d) && !('authorEmail' in d);
    }
    // accom(쉐어) + rent(렌트) — 매물 필드 + 스키마 화이트리스트
    function validShareRentCreate() {
      let d = request.resource.data;
      return validBaseCreate(d)
        && pOptStr(d, 'propType', 30)
        && pOptStr(d, 'minStay', 10)
        && pOptStr(d, 'gender', 20)
        && pOptStr(d, 'availableDate', 30)
        && pOptInt(d, 'price', 0, 9999999)
        && pOptInt(d, 'bedrooms', 0, 20)
        && pOptInt(d, 'bathrooms', 0, 20)
        && pOptInt(d, 'carSpaces', 0, 20)
        && pOptBool(d, 'parking')
        && pOptBool(d, 'petFriendly')
        && pOptBool(d, 'kidsInHouse')
        && pOptBool(d, 'airCon')
        && pOptBool(d, 'locationPrivate')
        && pOptList(d, 'imageUrls', 8)
        && pOptList(d, 'types', 10)
        && pOptList(d, 'roomTypes', 10)
        && d.keys().hasOnly([
             'uid', 'authorUid', 'author',
             'state', 'status', 'date', 'time', 'createdAt', 'updatedAt', 'id',
             'title', 'body', 'mode', 'contact', 'phone', 'kakaoLink', 'contactEmail',
             'address', 'lat', 'lng', 'locationPrivate', 'imageUrls',
             'propType', 'types', 'roomTypes', 'gender', 'availableDate', 'minStay',
             'bedrooms', 'bathrooms', 'carSpaces',
             'parking', 'petFriendly', 'kidsInHouse', 'airCon', 'price'
           ]);
    }
    // jobs(구인구직) — 고용 필드 + 스키마 화이트리스트
    function validJobsCreate() {
      let d = request.resource.data;
      return validBaseCreate(d)
        && pOptStr(d, 'postType', 20)
        && pOptStr(d, 'category', 40)
        && pOptStr(d, 'empType', 30)
        && pOptStr(d, 'payUnit', 20)
        && pOptInt(d, 'payAmount', 0, 9999999)
        && pOptBool(d, 'visaEligible')
        && pOptList(d, 'imageUrls', 8)
        && d.keys().hasOnly([
             'uid', 'authorUid', 'author',
             'state', 'status', 'date', 'time', 'createdAt', 'updatedAt', 'id',
             'title', 'body', 'mode', 'contact', 'phone', 'kakaoLink', 'contactEmail',
             'address', 'lat', 'lng', 'imageUrls',
             'postType', 'category', 'empType', 'payUnit', 'payAmount', 'visaEligible'
           ]);
    }
    // auto(차량) — 중고차/점검·긴급출동 필드 + 스키마 화이트리스트
    function validAutoCreate() {
      let d = request.resource.data;
      return validBaseCreate(d)
        && pOptStr(d, 'category', 40)
        && pOptStr(d, 'region', 300)
        && pOptStr(d, 'brand', 40)
        && pOptStr(d, 'model', 60)
        && pOptStr(d, 'year', 10)
        && pOptStr(d, 'mileage', 20)
        && pOptStr(d, 'rwc', 20)
        && pOptStr(d, 'regoExpiry', 20)
        && pOptStr(d, 'hours', 60)
        && pOptStr(d, 'timeSlot', 60)
        && pOptInt(d, 'price', 0, 9999999)
        && pOptInt(d, 'inspectionPrice', 0, 9999999)
        && pOptInt(d, 'emergencyPrice', 0, 9999999)
        && pOptBool(d, 'isPremium')
        && pOptBool(d, 'inspectionAvailable')
        && pOptBool(d, 'emergencyAvailable')
        && pOptBool(d, 'locationPrivate')
        && pOptList(d, 'imageUrls', 8)
        && d.keys().hasOnly([
             'uid', 'authorUid', 'author',
             'state', 'status', 'date', 'time', 'createdAt', 'updatedAt', 'id',
             'title', 'body', 'mode', 'contact', 'phone', 'kakaoLink', 'contactEmail',
             'address', 'lat', 'lng', 'locationPrivate', 'imageUrls',
             'category', 'region', 'brand', 'model', 'year', 'mileage',
             'rwc', 'regoExpiry', 'hours', 'isPremium', 'timeSlot',
             'inspectionAvailable', 'inspectionPrice',
             'emergencyAvailable', 'emergencyPrice', 'price'
           ]);
    }

    // services 일반 유저 create 검증기 (validAutoCreate 패턴 — let d + pOpt*(d), data() 재호출 0).
    //   · services 는 6개 보드(points/auto/gp/salon/restaurants/trades)가 제각각 스키마로 쓰는
    //     통합 컬렉션 → 풀 hasOnly 는 백로그(trades 업체폼 표준화 후). 현재는 미검증 문자열 길이캡(B-2a).
    //   · ⚠️ hoursJson(map)·lat/lng(float)·types/roomTypes(string[]) 는 캡 제외 — pOptStr 적용 시
    //     타입 불일치로 create 거부됨. 필드 추가 시 여기 캡만 갱신.
    function validServicesUserCreate() {
      let d = request.resource.data;
      return isVerifiedUser()
        && notSuspended()
        && (d.status == 'pending' || d.status == 'approved')
        && d.uid == request.auth.uid
        && pReqStr(d, 'category', 1, 50)
        && pReqStr(d, 'title', 1, 200)
        && pReqStr(d, 'contact', 1, 200)
        && pOptStr(d, 'region', 500)
        && pOptStr(d, 'address', 500)
        && pOptStr(d, 'summary', 500)
        && pOptStr(d, 'body', 5000)
        && pOptStr(d, 'state', 10)
        && pOptList(d, 'imageUrls', 8)
        // [B4] legal(법무법인/비자·이민) 글은 MARN 7자리 필수 — OMARA 등록 대리인만 (소비자 보호)
        && (d.category != 'legal'
            || ('marn' in d && d.marn is string && d.marn.matches('^[0-9]{7}$')))
        && pOptStr(d, 'marn', 7)
        && pOptStr(d, 'providedBy', 100)
        && pOptStr(d, 'lastReviewedAt', 30)
        // ── 미검증 문자열 필드 길이캡 (doc bloat 방어, B-2a) ──
        && pOptStr(d, 'phone', 30)
        && pOptStr(d, 'kakaoLink', 500)
        && pOptStr(d, 'contactEmail', 200)
        && pOptStr(d, 'tagline', 500)
        && pOptStr(d, 'visaType', 30)
        && pOptStr(d, 'hours', 200)
        && pOptStr(d, 'author', 100)
        && pOptStr(d, 'authorId', 64)
        && pOptStr(d, 'authorUid', 64)
        // H4: 공개 문서 작성자 PII 제거 — services 는 hasOnly 없음 → email/authorEmail 명시 차단(저장 금지).
        && !('email' in d) && !('authorEmail' in d)
        && pOptStr(d, 'mode', 20)
        && pOptStr(d, 'gender', 20)
        && pOptStr(d, 'availableDate', 40)
        && pOptInt(d, 'price', 0, 9999999)
        && pOptBool(d, 'adminPost')
        && pOptBool(d, 'isUserPost');
    }

    // ── 작성자 update 가드 (운영자 모더레이션 필드 변조 차단) ──
    //   · 일반 작성자가 자기 글을 수정할 때, 운영자 전용 필드(블라인드·신고누적·역할·모더레이션 타임스탬프)를
    //     새로 부여하거나 기존 값을 바꾸지 못하도록 잠근다.
    //   · status 는 별도 화이트리스트(statusAllowedForOwner) — 작성자가 'completed'/'closed' 자율 부여는 허용.
    //   · uid 잠금 — 작성자가 자기 글의 소유권을 다른 uid 로 이전(자기 글 회피)하는 공격 차단.
    //   · admin update 경로(forceUpdate 등)는 isAdmin() 분기에서 본 가드를 우회 — 운영 권한 보장.
    function moderatorOnlyFields() {
      // ⚠️ isHidden / hiddenAt 는 작성자도 본인 글 '일시 숨김' 토글 가능 (마이페이지 ⏸️/▶️)
      //    → 운영자 전용 잠금 목록에서 제외. 운영자/작성자 둘 다 토글 허용.
      //    단, uid 잠금(uidLocked) + status 화이트리스트(statusAllowedForOwner)는 그대로 유지.
      return ['reportCount', 'role', 'hiddenBy',
              'approvedAt', 'heldAt', 'pausedAt', 'closedAt'];
    }
    // ── admin 블라인드 잠금 (F-A) ──
    //   · admin 블라인드(hold)는 hiddenBy:'admin' 을 함께 저장 (admin-mark.js / koaus-rbac.js).
    //   · hiddenBy=='admin' 인 글은 작성자가 status/isHidden 을 되돌릴 수 없다
    //     (마이페이지 ▶️ 재노출 토글로 운영자 블라인드 자가 해제하던 구멍 봉쇄).
    //   · 작성자 본인 일시숨김은 hiddenBy 미보유 → 본 가드 통과 (기존 토글 유지).
    //   · hiddenBy 필드 자체는 moderatorOnlyFields 로 작성자 부여/변조 차단.
    function adminBlindLock() {
      return resource.data.get('hiddenBy', '') != 'admin'
        || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isHidden']);
    }
    function noModeratorFieldChange() {
      return !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(moderatorOnlyFields());
    }
    function uidLocked() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid']);
    }
    // 작성자가 status 를 부여 가능한 범위
    //   · 변경 없음 OR 'completed'(거래 완료) OR 'closed'(구인 마감)
    //   · 'hidden' ↔ 'approved' (마이페이지 ⏸️/▶️ 일시 숨김 토글 — 작성자 본인 글)
    function statusAllowedForOwner() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
        || request.resource.data.status == 'completed'
        || request.resource.data.status == 'closed'
        || request.resource.data.status == 'hidden'
        || request.resource.data.status == 'approved';
    }

    // ── 게시판 컬렉션 (현재 localStorage 스토어 → 향후 Firestore 전환 대비) ──
    //   koaus-accom-posts → accom_posts,  koaus-rent-posts → rent_posts,
    //   koaus-jobs-posts  → jobs_posts,   koaus-auto-posts → auto_posts
    // 작성자 본인(uid 매칭) 또는 관리자(isAdmin)는 강제 update/delete 가능 (블라인드·강제 수정·강제 삭제)
    match /accom_posts/{postId} {
      allow get:    if true;
      allow list:   if limitedList();
      allow create: if validShareRentCreate();
      allow update: if isAdmin()
                       || ( ownerOnExisting()
                            && uidLocked()
                            && noModeratorFieldChange()
                            && statusAllowedForOwner()
                            && adminBlindLock() );
      allow delete: if isAdmin() || ownerOnExisting();
    }
    match /rent_posts/{postId} {
      allow get:    if true;
      allow list:   if limitedList();
      allow create: if validShareRentCreate();
      allow update: if isAdmin()
                       || ( ownerOnExisting()
                            && uidLocked()
                            && noModeratorFieldChange()
                            && statusAllowedForOwner()
                            && adminBlindLock() );
      allow delete: if isAdmin() || ownerOnExisting();
    }
    match /jobs_posts/{postId} {
      allow get:    if true;
      allow list:   if limitedList();
      allow create: if validJobsCreate();
      allow update: if isAdmin()
                       || ( ownerOnExisting()
                            && uidLocked()
                            && noModeratorFieldChange()
                            && statusAllowedForOwner()
                            && adminBlindLock() );
      allow delete: if isAdmin() || ownerOnExisting();
    }
    match /auto_posts/{postId} {
      allow get:    if true;
      allow list:   if limitedList();
      allow create: if validAutoCreate();
      allow update: if isAdmin()
                       || ( ownerOnExisting()
                            && uidLocked()
                            && noModeratorFieldChange()
                            && statusAllowedForOwner()
                            && adminBlindLock() );
      allow delete: if isAdmin() || ownerOnExisting();
    }

    // ════════════════════════════════════════════════════════════════
    // 정확 위치 정보 서브컬렉션 (지시 2/5 — 위치 프라이버시 대공사)
    //   각 매물 글이 '비공개(locationPrivate:true)'로 등록된 경우,
    //   부모 doc 의 lat/lng/address 는 300~500m 오프셋된 대략 위치만 저장하고
    //   정확한 주소·좌표는 본 서브컬렉션 (private_data/location) 에 별도 저장.
    //
    //   접근 제어 (보안 차단막):
    //     · get:    작성자 본인(ownerUid==auth.uid) 또는 admin 만 허용
    //     · list:   완전 차단 — 도큐먼트 ID(예: 'location') 알아야 read 가능
    //                (어뷰징·대량 수집·역지오코딩 공격 방어)
    //     · create: 본인(ownerUid==auth.uid) + 부모 doc 의 uid 도 본인 일치 강제
    //                (다른 사람 글에 정확 위치 강제 부여 차단)
    //     · update/delete: 작성자 본인 또는 admin
    //
    //   필드 검증:
    //     · exactAddress (required, 1-500): 정확 도로명·번지 포함 주소
    //     · exactLat, exactLng (required number): 정확 좌표 (-90~90, -180~180)
    //     · ownerUid (required string): 부모 doc 의 uid 와 동일 — read 검증용
    //     · createdAt (serverTimestamp 권장): 작성 시점
    //
    //   향후 확장 포인트: 예약 승인 흐름 도입 시 'approvedBookingUids' 같은
    //                       필드 + 조건문 추가하여 승인된 다른 사용자에게도 read 개방.
    // ════════════════════════════════════════════════════════════════
    match /accom_posts/{postId}/private_data/{docId} {
      allow get:  if isSignedIn()
                     && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow list: if false;
      allow create: if isAdmin()
                       || ( isSignedIn()
                            && request.resource.data.ownerUid == request.auth.uid
                            && get(/databases/$(database)/documents/accom_posts/$(postId)).data.uid == request.auth.uid
                            && reqStr('exactAddress', 1, 500)
                            && request.resource.data.exactLat is number
                            && request.resource.data.exactLng is number
                            && request.resource.data.exactLat >= -90
                            && request.resource.data.exactLat <= 90
                            && request.resource.data.exactLng >= -180
                            && request.resource.data.exactLng <= 180 );
      allow update, delete: if isAdmin()
                               || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }
    match /rent_posts/{postId}/private_data/{docId} {
      allow get:  if isSignedIn()
                     && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow list: if false;
      allow create: if isAdmin()
                       || ( isSignedIn()
                            && request.resource.data.ownerUid == request.auth.uid
                            && get(/databases/$(database)/documents/rent_posts/$(postId)).data.uid == request.auth.uid
                            && reqStr('exactAddress', 1, 500)
                            && request.resource.data.exactLat is number
                            && request.resource.data.exactLng is number
                            && request.resource.data.exactLat >= -90
                            && request.resource.data.exactLat <= 90
                            && request.resource.data.exactLng >= -180
                            && request.resource.data.exactLng <= 180 );
      allow update, delete: if isAdmin()
                               || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }
    // ════════════════════════════════════════════════════════════════
    // deletion_errors — 매물 삭제 부분 실패 로그 (좀비 데이터 추적)
    //   · 클라이언트 삭제(selfDelete/forceDelete) 가 원자적이지 않아
    //     private_data / Storage / 부모 doc 중 일부 실패 시 본 컬렉션에
    //     [board, docId, uid, failed, errorMsg, remainingImageUrls, exactAddress]
    //     를 기록 → admin 이 일괄 정리 가능.
    //   · ⚠️ 보안 강제: exactAddress 등 민감정보 포함 → admin 만 read.
    //     일반 사용자는 create 만 가능 (자기 글 실패 기록).
    //   · update / delete — admin 만 (운영자 정리 후 처리)
    // ════════════════════════════════════════════════════════════════
    match /deletion_errors/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn()
                       && request.resource.data.uid == request.auth.uid
                       && reqStr('board', 1, 30)
                       && reqStr('docId', 1, 100);
      allow update, delete: if isAdmin();
    }

    match /auto_posts/{postId}/private_data/{docId} {
      allow get:  if isSignedIn()
                     && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow list: if false;
      allow create: if isAdmin()
                       || ( isSignedIn()
                            && request.resource.data.ownerUid == request.auth.uid
                            && get(/databases/$(database)/documents/auto_posts/$(postId)).data.uid == request.auth.uid
                            && reqStr('exactAddress', 1, 500)
                            && request.resource.data.exactLat is number
                            && request.resource.data.exactLng is number
                            && request.resource.data.exactLat >= -90
                            && request.resource.data.exactLat <= 90
                            && request.resource.data.exactLng >= -180
                            && request.resource.data.exactLng <= 180 );
      allow update, delete: if isAdmin()
                               || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // ── 문의 메일 (contact.html → 'mail' 컬렉션, 쓰기 전용) ──
    //   누구나 1건 보낼 수 있으나 읽기/수정/삭제 전면 금지 + 필드 검증.
    //   봇의 대량 전송은 App Check(reCAPTCHA v3)로 차단.
    match /mail/{mailId} {
      allow read:           if false;
      allow create:         if reqStr('message', 1, 5000)
                               && optStr('subject', 200)
                               && optStr('email', 200)
                               && optStr('name', 100);
      allow update, delete: if false;
    }

    // ── 사용자 문서 ──
    //   · 본인 직접 get/write: 본인 uid 만
    //   · 관리자: 강제 권한 (운영·민원 처리·계정 제재 목적 — get/update/delete + list ≤100 가능)
    //   · list: admin 한정 ≤100 (제재 관리 카드 — status=='suspended' 조회용)
    //     · 비admin 은 전면 차단 유지 — 옛 'where(field+securityA) limit 1' 우회 enumeration 봉쇄
    //     · 아이디/비번 찾기는 nicknames/{nick}, emails/{email} 단일 get 으로 분리됨
    //   · ⚠️ 권한 무결성: 본인이 자기 자신을 admin으로 만드는 변조 차단.
    //     - 본인 update 경로에서는 isAdmin/email 필드를 새로 추가하거나 값 변경 금지 (inline 가드).
    //     - admin이 직접 콘솔 또는 setAdmin.js로 부여하는 경우(admin update 경로)만 가능.
    match /users/{uid} {
      allow get:    if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow list:   if isAdmin() && request.query.limit <= 100;
      allow create: if isSignedIn() && request.auth.uid == uid
                       // 가입 시점 isAdmin 자체 부여 차단 — admin 전용 권한은 setAdmin.js 로만
                       && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false)
                       // role 필드 자체 부여 차단 (시스템 향후 확장 대비 — 'user' 외 값 봉쇄)
                       && (!('role' in request.resource.data) || request.resource.data.role == 'user')
                       // status 자체 부여 차단 — 제재 상태는 suspendUser callable(Admin SDK) 전용
                       && !('status' in request.resource.data);
      allow update: if isAdmin()
                       || ( isSignedIn()
                            && request.auth.uid == uid
                            // 본인 update — isAdmin 필드 변경 금지 (없거나 / 기존 값 동일)
                            && (!('isAdmin' in request.resource.data)
                                || (('isAdmin' in resource.data) && request.resource.data.isAdmin == resource.data.isAdmin))
                            // email 필드 변조 금지 (가입 시 set 한 값 그대로)
                            && (!('email' in request.resource.data)
                                || (('email' in resource.data) && request.resource.data.email == resource.data.email))
                            // role 필드 변조 금지 (없거나 / 기존 값 동일)
                            && (!('role' in request.resource.data)
                                || (('role' in resource.data) && request.resource.data.role == resource.data.role))
                            // status 변조 금지 (F-B) — 정지자가 자기 status 를 'active' 로 되돌리는 우회 차단
                            && (!('status' in request.resource.data)
                                || (('status' in resource.data) && request.resource.data.status == resource.data.status))
                          );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // ── 닉네임 색인(중복 방지 + 아이디 찾기) ──
    //   · doc id = nickname.toLowerCase() (case-insensitive 유일성)
    //   · get: 누구나 1건 조회 (가입 전 중복 체크 + 아이디 찾기 nick+secA 매칭)
    //   · list: 전면 차단 (열거 방지)
    //   · create/update/delete: 본인(uid) 소유만
    match /nicknames/{nick} {
      allow get:    if true;
      allow list:   if false;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
                       && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── 이메일 색인(비번 찾기) ──
    //   · doc id = email.toLowerCase()
    //   · get: 누구나 1건 조회 (비번 찾기 email+secA 매칭 후 sendPasswordResetEmail)
    //   · list: 전면 차단 (열거 방지)
    //   · create/update/delete: 본인(uid) 소유만 (회원가입 트랜잭션 1회)
    match /emails/{email} {
      allow get:    if true;
      allow list:   if false;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
                       && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── 신고(reports) — 제재 시스템 3단계 (2026-06-11 확장) ──
    //   · 문서 ID = {postId}_{reporterUid} — 같은 글 재신고는 동일 ID create 시도
    //     → Firestore 가 이미 존재하는 doc 의 create 를 거부 (중복 신고 원천 차단).
    //     rules 의 ID 패턴 강제는 임의 ID(addDoc 등)로 패턴을 우회하는 경로 차단.
    //   · 신고 시점 스냅샷(postAuthorUid/postTitle/postBodyExcerpt) — 원글 삭제 후에도 검토 가능.
    //   · read/update/delete: admin 전용 — 옛 '신고자 본인 get' 회수
    //     (클라이언트에 자기 신고 조회 기능 없음 — 영향 0, 최소권한 환원).
    //   · list limit 100 — admin.html 구독 limit 과 정합 (F-G: 옛 200 구독이 거부되던 버그).
    match /reports/{reportId} {
      allow create: if isSignedIn()
                       && notSuspended()
                       && data().reporterUid == request.auth.uid
                       && reqStr('postId', 1, 100)
                       && reportId == data().postId + '_' + request.auth.uid
                       && reqStr('reason', 1, 1000)
                       && reqStr('board', 1, 30)
                       && optStr('postTitle', 200)
                       && optStr('category', 30)
                       && optStr('detail', 1000)
                       && optStr('reporterEmail', 200)
                       && optStr('postAuthorUid', 128)
                       && optStr('postBodyExcerpt', 300)
                       && optStr('status', 30)
                       && data().keys().hasOnly([
                            'postId', 'board', 'postTitle', 'category', 'reason', 'detail',
                            'reporterUid', 'reporterEmail', 'postAuthorUid', 'postBodyExcerpt',
                            'status', 'createdAt'
                          ]);
      allow get:    if isAdmin();
      allow list:   if isAdmin() && request.query.limit <= 100;
      allow update, delete: if isAdmin();
    }

    // ── 제재 로그(moderation_logs) — suspendUser/unsuspendUser callable 전용 기록 ──
    //   · 쓰기: Functions(Admin SDK) 만 — rules 우회. 클라이언트 쓰기 전면 차단.
    //   · 읽기: admin 만 (대상 이메일 등 PII 포함).
    match /moderation_logs/{logId} {
      allow get:  if isAdmin();
      allow list: if isAdmin() && request.query.limit <= 100;
      allow create, update, delete: if false;
    }

    // ── 차량/렌터카 문의(listing_inquiries) — auto.html 인콰이어리 모달 silent backup ──
    //   · 실제 흐름은 mailto: 메일 발송 우선, Firestore 저장은 best-effort 백업 (catch silent)
    //   · 누구나 1건 create 가능 (비로그인 포함 — 사용자 명시 흐름 유지)
    //   · read/list 는 개인정보(name/contact/email/message) 보호로 관리자 전용
    //   · 필드 길이 강제로 빌링 폭탄 차단
    match /listing_inquiries/{id} {
      allow get:    if isAdmin();
      allow list:   if isAdmin() && request.query.limit <= 200;
      allow create: if reqStr('message', 1, 5000)
                       && optStr('category', 100)
                       && optStr('state', 10)
                       && optStr('name', 100)
                       && optStr('contact', 100)
                       && optStr('email', 200);
      allow update, delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════
    // 관리자 전용 컬렉션 (notices / sponsors / services)
    //   - 읽기:  비회원 포함 모든 방문자 허용 (홈/서비스 페이지 실시간 노출용)
    //   - 쓰기:  custom claim {admin: true} 보유 계정만 (Admin SDK로 부여)
    //   - 목록:  limit ≤ 20 강제 (요금 폭탄 방어)
    // ════════════════════════════════════════════════════════════════

    // 흐르는 공지사항 (홈 상단 마퀴 — marquee.js onSnapshot 대상)
    //   · 읽기: 누구나 (마퀴 노출)
    //   · 쓰기: isAdmin() 만 (3중 안전망 그대로 — Custom Claim OR sinhang0122 OR users/{uid}.isAdmin)
    //   · 필수: text (마퀴 본문)
    //   · 옵션: link/url (클릭 이동 URL), sponsor (좌측 라벨), action ('link'),
    //          priority (정렬 가중치), active (노출 토글)
    //          → admin.html 카드 2 (상단 노출 공지) 풀 payload 호환
    //   · 비admin write 거부 / 임의 필드는 옵션 검증으로만 통제 (보안 약화 0)
    match /notices/{id} {
      allow read: if true;
      // delete 는 데이터 검증과 분리 — delete 요청엔 request.resource.data 가 없어
      // create/update 와 묶으면 reqStr 평가가 에러 → admin 도 삭제 불가 버그 (2026-06 수정)
      allow create, update: if isAdmin()
                               && reqStr('text', 1, 1000)
                               && optStr('link', 500)
                               && optStr('url', 500)
                               && optStr('sponsor', 100)
                               && optStr('action', 30)
                               && optInt('priority', 0, 9999)
                               && optBool('active');
      allow delete: if isAdmin();
      allow list: if limitedList();
    }

    // 광고주 / 스폰서 (홈 상단 광고 마퀴)
    match /sponsors/{id} {
      allow read: if true;
      allow create, update: if isAdmin()
                                       && reqStr('name', 1, 200)
                                       && optStr('link', 500)
                                       && optStr('memo', 500);
      allow delete: if isAdmin();
      allow list: if limitedList();
    }

    // 전역 롤링 배너 (모든 페이지 상단 ticker — sponsor + content + linkUrl)
    match /global_ticker/{id} {
      allow read: if true;
      allow create, update: if isAdmin()
                                       && reqStr('sponsor', 1, 100)
                                       && reqStr('content', 1, 500)
                                       && optStr('linkUrl', 500);
      allow delete: if isAdmin();
      allow list: if limitedList();
    }

    // 관리자 광고 배너 (홈 광고칸 — 이미지 + 클릭 URL)  [LEGACY — admin UI에서 제거됨, 데이터 보존용]
    match /ads/{id} {
      allow read: if true;
      allow create, update: if isAdmin()
                                       && reqStr('image', 1, 500)
                                       && reqStr('link', 1, 500)
                                       && optStr('alt', 200)
                                       && optStr('memo', 500);
      allow delete: if isAdmin();
      allow list: if limitedList();
    }

    // ── 히어로 배너 (서브페이지 상단 swiper) ──
    //   · imageUrl: 배너 이미지 URL (https)
    //   · linkUrl:  클릭 시 이동할 URL (optional)
    //   · alt:      대체 텍스트 / 배너 이름
    //   · regions:  노출 지역 배열 — ['all'] 또는 ['nsw','vic',...] (max 9)
    //   · order:    정렬 순서 (낮을수록 앞)
    //   · active:   노출 여부
    //   · start/end: 노출 기간 'YYYY-MM-DD' (optional — 빈 값은 키 생략/삭제)
    //   · house:    하우스 광고 여부 (optional bool — 광고주 배너보다 낮은 우선순위)
    //   · read:     누구나 — 서브 페이지에서 클라이언트가 직접 fetch 후 필터링
    //   · write:    관리자만 — 이미지/링크 URL 길이 + regions 배열 크기 강제 (빌링 안전망)
    match /hero_banners/{id} {
      allow read: if true;
      allow list: if limitedList();
      allow create, update: if isAdmin()
                                       && reqStr('imageUrl', 1, 500)
                                       && optStr('linkUrl', 500)
                                       && optStr('alt', 200)
                                       && optStr('start', 10)
                                       && optStr('end', 10)
                                       && optBool('house')
                                       && request.resource.data.regions is list
                                       && request.resource.data.regions.size() <= 9;
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════
    // services 컬렉션 (Approval Pipeline — 모든 6 대 섹션 통합)
    //   카테고리: maintenance / inspection / rental / towing / accom /
    //             legal / education / trades / restaurants / gp
    //
    //   ── 읽기 (read = get + list) ──
    //   - admin: 모든 status(pending·approved 무관) 읽기 무제한.
    //   - 비admin(비로그인 포함): status == 'approved' 인 문서만.
    //     · doc id 추측 공격 차단: get 시 resource.data.status 검사.
    //     · list 시 쿼리에 where('status','==','approved') 가 없으면
    //       pending doc 의 read 룰이 실패해 전체 쿼리 거부 → 클라이언트가
    //       반드시 where 절 포함 (코드 측에서 보장).
    //
    //   ── 생성 (create) ──
    //   - admin: status 자유 (보통 'approved' 직접 등록).
    //   - 일반 로그인 유저: status == 'pending' 으로만 생성 가능.
    //     본인 uid + 필수 필드(category/title/contact) + 길이 제한.
    //
    //   ── 수정/삭제 (update/delete) ──
    //   - admin 전용 (승인은 status='approved' 로 update, 반려는 delete).
    //
    //   ── 목록 limit ──
    //   - 비admin: list 시 limit ≤ 50 강제 (요금 폭탄 방어).
    //   - admin:   list 시 limit ≤ 200 허용 (대기열 일괄 조회).
    // ════════════════════════════════════════════════════════════════
    match /services/{id} {
      // 읽기: admin 전체 / 비admin 은 approved 글만
      // (오피셜 인증 기능 폐기 2026-06-11 — isOfficial 조건 제거. 기존 isOfficial 데이터는
      //  전수 approved 였고 필드도 Admin SDK 로 일괄 삭제 — 노출 범위 불변)
      allow get: if isAdmin()
                    || resource.data.status == 'approved';

      // list 평가: doc 별 read 룰이 모두 통과해야 전체 쿼리 통과
      // → 비admin 은 클라이언트에서 where('status','==','approved') 필수
      allow list: if (isAdmin() && request.query.limit <= 200)
                     || request.query.limit <= 50;

      allow create: if
        // ① admin 직접 등록 (status 자유)
        ( isAdmin()
          && reqStr('category', 1, 50)
          && reqStr('title', 1, 200)
          && optStr('region',  500)
          && optStr('address', 500)
          && optStr('summary', 500)
          && optStr('body',   5000)
          && optStr('contact', 200)
          && optStr('state',    10)
          && optStr('status',   30)
          && optUrlList('imageUrls', 8)
        )
        // ② 일반 로그인 유저 등록 — 자율 등록형 게시판 (UGC). 검증기 분리(validAutoCreate 패턴):
        //    let d + pOpt*(d) 로 data() 재호출 0 → 1,000 표현식 한도 안전(B-2a 길이캡 16종 포함).
        || validServicesUserCreate();

      // 본인 글 수정/삭제 허용 (RBAC 작성자 액션) + admin 강제 권한
      //   · 작성자: uid 매칭 + uid 잠금 + 운영자 모더레이션 필드 변조 차단 + status 화이트리스트
      //     (일반 필드 patch — title/body/category/region/address/contact/imageUrls 등은 자유)
      //   · admin: 강제 권한 (블라인드·강제 수정·강제 삭제 — 가드 우회)
      allow update: if isAdmin()
                       || ( isSignedIn()
                            && resource.data.uid == request.auth.uid
                            && notSuspended()
                            && uidLocked()
                            && noModeratorFieldChange()
                            && statusAllowedForOwner()
                            && adminBlindLock() );
      allow delete: if isAdmin()
                       || (isSignedIn() && resource.data.uid == request.auth.uid && notSuspended());
    }

    // ════════════════════════════════════════════════════════════════
    // board_pinned_notices — 게시판 상단 핀공지 (게시판당 1 doc)
    //   - doc id: accom / rent / jobs / trades / restaurants / gp 등
    // ════════════════════════════════════════════════════════════════
    match /board_pinned_notices/{board} {
      allow read: if true;
      allow create, update: if isAdmin()
                                       && reqStr('text', 1, 1000)
                                       && optStr('title', 200)
                                       && optStr('board', 30);
      allow delete: if isAdmin();
      allow list: if limitedList();
    }

    // ── 광고 배너 (ad_banners) — 지시 [두더지 잡기 방지! 광고 시스템] ──
    //   · koaus-ads.js + admin-ads.html 연동 컬렉션 (사용자 제공 모듈)
    //   · 읽기: 누구나 (홈 히어로 슬라이더 옆에 append — onAd 콜백)
    //   · 쓰기: admin 만 + 필드 길이 강제 + Storage URL 검증
    //   · list: admin 페이지가 active==true 전체 fetch (limit 미명시) → 광고 수 적음, 안전
    match /ad_banners/{id} {
      allow get:    if true;
      allow list:   if limitedList();    // ≤20 — 빌링폭탄 방어 (옛 무제한 list 제거)
      allow create, update: if isAdmin()
                               && reqStr('img',    1, 1000)
                               && optStr('href',         1500)
                               && optStr('alt',           200)
                               && optStr('state',          30)
                               && optStr('imgPath',       500)
                               && optStr('start',          30)
                               && optStr('end',            30);
      allow delete: if isAdmin();
    }

    // ── 상단 노출 공지 (top_notices) — 지시 7/7 admin 카드 2 ──
    //   · sponsor + priority + action + url + text + active
    //   · 읽기: 누구나 (홈 상단 노출용)
    //   · 쓰기: admin 전용 + 필드 길이 강제
    match /top_notices/{id} {
      allow read: if true;
      allow list: if limitedList();
      allow create, update: if isAdmin()
                                       && reqStr('sponsor', 1, 100)
                                       && reqStr('text', 1, 1000)
                                       && optStr('url', 500)
                                       && optStr('action', 30);
      allow delete: if isAdmin();
    }

    // ── 앱 전역 설정 (지시 7/7) ──
    //   · app_settings/timings 1개 doc → { heroDelaySec, marqueeDurationSec, updatedAt }
    //   · 읽기: 누구나 (홈/카테고리 페이지에서 hero-banner/marquee 시간 초기화 시 fetch)
    //   · 쓰기: admin 만 + 숫자 범위 + 빌링 폭탄 방어
    //   · list: enumeration 차단 (단일 doc id 'timings' 만 get 으로 접근)
    match /app_settings/{id} {
      allow get:    if true;
      allow list:   if false;
      allow create, update: if isAdmin()
                               && optInt('heroDelaySec',       1,   30)
                               && optInt('marqueeDurationSec', 5,  300);
      allow delete: if isAdmin();
    }

    // ── 그 외 모든 경로: 기본 거부 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
